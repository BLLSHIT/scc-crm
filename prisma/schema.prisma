generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  sales
  project_manager
  viewer
}

model Settings {
  id                    String   @id @default("singleton")
  companyName           String?
  companyAddress        String?
  companyZip            String?
  companyCity           String?
  companyCountry        String?  @default("Deutschland")
  companyEmail          String?
  companyPhone          String?
  companyWebsite        String?
  taxNumber             String?
  ustId                 String?
  companyRegisterNumber String?
  bankName              String?
  bankIban              String?
  bankBic               String?
  logoUrl               String?
  defaultQuoteValidity  Int      @default(30)
  defaultInvoiceDueDays Int      @default(14)
  quoteNumberPrefix     String   @default("AN")
  invoiceNumberPrefix   String   @default("RE")
  nextQuoteSeq          Int      @default(1)
  nextInvoiceSeq        Int      @default(1)
  currentYear           Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

enum InvoiceStatus {
  draft
  open
  paid
  overdue
  cancelled
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  title         String
  status        InvoiceStatus @default(draft)
  issueDate     DateTime      @default(now())
  dueDate       DateTime

  companyId    String?
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId    String?
  contact      Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  teamMemberId String?
  teamMember   TeamMember? @relation("InvoiceTeamMember", fields: [teamMemberId], references: [id], onDelete: SetNull)
  dealId       String?
  deal         Deal?       @relation(fields: [dealId], references: [id], onDelete: SetNull)
  quoteId      String?
  quote        Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  subtotalNet           Decimal @default(0)  @db.Decimal(12, 2)
  totalDiscount         Decimal @default(0)  @db.Decimal(12, 2)
  globalDiscountPercent Decimal @default(0)  @db.Decimal(5, 2)
  totalVat              Decimal @default(0)  @db.Decimal(12, 2)
  totalGross            Decimal @default(0)  @db.Decimal(12, 2)
  totalPaid             Decimal @default(0)  @db.Decimal(12, 2)

  greeting     String?
  intro        String?
  footer       String?
  paymentTerms String?

  sentAt      DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?

  lineItems InvoiceLineItem[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([companyId])
  @@index([dealId])
  @@index([quoteId])
  @@map("invoices")
}

model InvoiceLineItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation("InvoiceLineItemProduct", fields: [productId], references: [id], onDelete: SetNull)

  itemType        String  @default("product")
  name            String
  description     String?
  imageUrl        String?
  unit            String  @default("Stück")
  quantity        Decimal @default(1)  @db.Decimal(12, 2)
  unitPriceNet    Decimal @default(0)  @db.Decimal(12, 2)
  discountPercent Decimal @default(0)  @db.Decimal(5, 2)
  vatRate         Decimal @default(19) @db.Decimal(5, 2)
  isOptional      Boolean @default(false)
  sortOrder       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(12, 2)
  paymentDate    DateTime @default(now())
  paymentMethod  String?
  reference      String?
  notes          String?
  recordedBy     String?
  recordedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId, paymentDate])
  @@map("payments")
}

enum QuoteStatus {
  draft
  sent
  accepted
  declined
  expired
}

model Quote {
  id            String       @id @default(cuid())
  quoteNumber   String       @unique
  title         String
  status        QuoteStatus  @default(draft)
  validUntil    DateTime

  companyId    String?
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId    String?
  contact      Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  teamMemberId String?
  teamMember   TeamMember? @relation("QuoteTeamMember", fields: [teamMemberId], references: [id], onDelete: SetNull)
  dealId       String?
  deal         Deal?       @relation(fields: [dealId], references: [id], onDelete: SetNull)

  subtotalNet           Decimal @default(0)  @db.Decimal(12, 2)
  totalDiscount         Decimal @default(0)  @db.Decimal(12, 2)
  totalVat              Decimal @default(0)  @db.Decimal(12, 2)
  totalGross            Decimal @default(0)  @db.Decimal(12, 2)
  globalDiscountPercent Decimal @default(0)  @db.Decimal(5, 2)

  greeting      String?
  intro         String?
  footer        String?
  paymentTerms  String?

  sentAt        DateTime?
  acceptedAt    DateTime?
  declinedAt    DateTime?

  lineItems     QuoteLineItem[]
  invoices      Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([companyId])
  @@index([dealId])
  @@map("quotes")
}

model QuoteLineItem {
  id              String  @id @default(cuid())
  quoteId         String
  quote           Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  itemType        String  @default("product")
  name            String
  description     String?
  imageUrl        String?
  unit            String  @default("Stück")
  quantity        Decimal @default(1) @db.Decimal(12, 2)
  unitPriceNet    Decimal @default(0) @db.Decimal(12, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  vatRate         Decimal @default(19) @db.Decimal(5, 2)
  isOptional      Boolean @default(false)
  sortOrder       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("quote_line_items")
}

model Industry {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("industries")
}

model LeadSource {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lead_sources")
}

model ProductCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_categories")
}

model Product {
  id              String  @id @default(cuid())
  name            String
  description     String?
  sku             String?
  category        String?
  unit            String  @default("Stück")
  defaultPriceNet  Decimal @default(0) @db.Decimal(12, 2)
  purchasePriceNet Decimal @default(0) @db.Decimal(12, 2)
  defaultVatRate   Decimal @default(19) @db.Decimal(5, 2)
  imageUrl        String?
  isActive        Boolean @default(true)

  quoteLineItems   QuoteLineItem[]
  invoiceLineItems InvoiceLineItem[] @relation("InvoiceLineItemProduct")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("products")
}

enum TextModuleType {
  greeting
  intro
  footer
  payment_terms
  other
}

model TextModule {
  id        String         @id @default(cuid())
  name      String
  type      TextModuleType
  content   String
  isDefault Boolean        @default(false)
  sortOrder Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("text_modules")
}

model TeamMember {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String  @unique
  mobile    String?
  position  String?
  abbreviation String?
  avatarUrl String?
  isActive  Boolean @default(true)

  deals    Deal[]    @relation("DealTeamMember")
  quotes   Quote[]   @relation("QuoteTeamMember")
  invoices Invoice[] @relation("InvoiceTeamMember")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_members")
}

model Profile {
  id        String   @id
  email     String   @unique
  firstName String
  lastName  String
  role      UserRole @default(sales)
  avatarUrl String?
  isActive  Boolean  @default(true)

  ownedContacts Contact[] @relation("ContactOwner")
  ownedDeals    Deal[]    @relation("DealOwner")
  assignedTasks Task[]    @relation("TaskAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

enum TaskStatus {
  open
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(open)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?

  assigneeId String?
  assignee   Profile? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assigneeId])
  @@index([dueDate])
  @@index([status])
  @@map("tasks")
}

model Company {
  id       String  @id @default(cuid())
  name     String
  website  String?
  industry String?
  size     String?
  country  String?
  city     String?
  phone     String?
  email     String?
  linkedin  String?
  instagram String?
  tags      String[] @default([])

  contacts Contact[]
  deals    Deal[]
  tasks    Task[]
  quotes   Quote[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model Contact {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  mobile    String?
  linkedin  String?
  instagram String?
  position  String?
  source    String?
  tags      String[] @default([])
  notes     String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  ownerId   String?
  owner     Profile? @relation("ContactOwner", fields: [ownerId], references: [id])

  deals    DealContact[]
  tasks    Task[]
  quotes   Quote[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("contacts")
}

model Pipeline {
  id        String          @id @default(cuid())
  name      String
  isDefault Boolean         @default(false)
  stages    PipelineStage[]
  deals     Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pipelines")
}

model PipelineStage {
  id          String  @id @default(cuid())
  name        String
  order       Int
  probability Float   @default(0)
  color       String  @default("#6366f1")
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals      Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pipelineId, order])
  @@map("pipeline_stages")
}

model Deal {
  id              String    @id @default(cuid())
  title           String
  value           Decimal   @default(0) @db.Decimal(12, 2)
  currency        String    @default("EUR")
  probability     Float     @default(0)
  expectedCloseAt DateTime?
  description     String?
  lostReason      String?

  pipelineId String
  pipeline   Pipeline      @relation(fields: [pipelineId], references: [id])
  stageId    String
  stage      PipelineStage @relation(fields: [stageId], references: [id])
  companyId  String?
  company    Company?      @relation(fields: [companyId], references: [id])
  ownerId    String?
  owner      Profile?      @relation("DealOwner", fields: [ownerId], references: [id])

  teamMemberId String?
  teamMember   TeamMember? @relation("DealTeamMember", fields: [teamMemberId], references: [id], onDelete: SetNull)

  projectStatus String?

  contacts DealContact[]
  tasks    Task[]
  quotes   Quote[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stageId])
  @@map("deals")
}

model DealContact {
  dealId    String
  contactId String
  role      String?

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([dealId, contactId])
  @@map("deal_contacts")
}
